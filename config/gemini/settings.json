{
  "general": {
    "preferredEditor": "nvim",
    "vimMode": true,
    "disableAutoUpdate": true,
    "disableUpdateNag": false,
    "checkpointing": {
      "enabled": false
    },
    "previewFeatures": true,
    "enableAutoUpdate": false,
    "enableAutoUpdateNotification": true
  },
  "output": {
    "format": "text"
  },
  "ui": {
    "theme": "ANSI"
  },
  "ide": {
    "enabled": true,
    "hasSeenNudge": true
  },
  "privacy": {
    "usageStatisticsEnabled": false
  },
  "context": {
    "fileName": [
      "AGENTS.md",
      "CLAUDE.md",
      "CONTEXT.md",
      "GEMINI.md"
    ]
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "mcpServers": {
    "github": {
      "command": "pnpm",
      "args": [
        "dlx",
        "mcp-remote@0.1.38",
        "https://api.githubcopilot.com/mcp/",
        "--header",
        "Authorization: Bearer $GITHUB_PERSONAL_ACCESS_TOKEN"
      ],
      "env": {
        "GITHUB_TOOLSETS": "default,code_security,secret_protection,security_advisories",
        "GITHUB_LOCKDOWN_MODE": "1"
      }
    },
    "context7": {
      "command": "pnpm",
      "args": [
        "dlx",
        "@upstash/context7-mcp@2.1.1"
      ]
    },
    "sequentialthinking": {
      "command": "pnpm",
      "args": [
        "dlx",
        "@modelcontextprotocol/server-sequential-thinking@2025.12.18"
      ]
    },
    "time": {
      "command": "uvx",
      "args": [
        "mcp-server-time==2026.1.26"
      ]
    },
    "git": {
      "command": "uvx",
      "args": [
        "mcp-server-git==2026.1.14"
      ]
    },
    "gitlab-csui": {
      "command": "pnpm",
      "args": [
        "dlx",
        "@zereight/mcp-gitlab@2.0.30"
      ],
      "env": {
        "GITLAB_PERSONAL_ACCESS_TOKEN": "$GITLAB_CSUI_PERSONAL_ACCESS_TOKEN",
        "GITLAB_API_URL": "$GITLAB_CSUI_API_URL",
        "GITLAB_DENIED_TOOLS_REGEX": "(label|labels|release|releases|release_evidence|release_asset|namespace|namespaces)$",
        "USE_GITLAB_WIKI": "false",
        "USE_PIPELINE": "false",
        "USE_MILESTONE": "true"
      }
    },
    "microsoft-learn": {
      "httpUrl": "https://learn.microsoft.com/api/mcp"
    }
  }
}
