[core]
    autocrlf = input
    editor = vi
[color]
    ui = auto
[init]
    defaultBranch = main
[commit]
    gpgSign = true
    verbose = true
[gpg]
    format = ssh
[push]
    default = simple
    autoSetupRemote = true
    gpgSign = if-asked
[user]
    useConfigOnly = true
    signingKey = ~/.ssh/id_ed25519.pub
    name = Daya Adianto
    email = addianto@users.noreply.github.com
[diff]
    algorithm = histogram
    colorMoved = plain
    mnemonicPrefix = true
    renames = true
[rerere]
    enabled = true
    autoUpdate = true
[rebase]
    updateRefs = true
[column]
    ui = auto
[branch]
    sort = -committerdate
[tag]
    sort = version:refname
    gpgSign = true
[help]
    autocorrect = prompt
[alias]
    force-push = push --force-with-lease
    log-graph = log --graph --oneline --color
    root = rev-parse --show-toplevel
    search = log -E -i --grep
    stash-all = stash --all
    word-diff = diff --word-diff --ignore-all-space
    unstage = reset HEAD
    uncommit = reset --soft HEAD^
[gpg "ssh"]
    allowedSignersFile = ~/.config/git/allowed_signers
